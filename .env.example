# ---------------------------------------------------------------------------
# Base de datos (Turso / libSQL)
# ---------------------------------------------------------------------------
# En producción (Vercel) DEBES definir estas dos variables. Se obtienen al
# crear la base en https://turso.tech :
#   turso db show <nombre> --url        -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create <nombre>     -> TURSO_AUTH_TOKEN
#
# En desarrollo local puedes dejarlas vacías: la app usa un archivo SQLite
# local (file:reclamaciones.db) automáticamente.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Subida de imágenes (Vercel Blob)
# ---------------------------------------------------------------------------
# En Vercel se inyecta sola al conectar un Blob Store al proyecto.
# Para probar subidas en local, pega aquí el token del Blob Store.
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------------------
# Credenciales del panel de administración (ya existentes en tu proyecto)
# ---------------------------------------------------------------------------
# ADMIN_USER=
# ADMIN_PASSWORD=
